---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="wrap">
        <div class="hero-eyebrow">
          <span class="dot"></span>
          Now in early access
        </div>
        <h1>Your move, <em>handled.</em></h1>
        <p class="hero-sub">Stop wondering what you're forgetting. MoveMatters builds your personalized moving checklist and walks you through it — one task at a time.</p>
        <form class="hero-form" name="waitlist" data-netlify="true" onsubmit="handleNetlifySignup(event, this);">
          <input type="hidden" name="form-name" value="waitlist" />
          <input class="input" type="email" name="email" placeholder="your@email.com" aria-label="Email address" required />
          <button class="btn btn-primary btn-arrow" type="submit">
            Get Early Access
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="M13 6l6 6-6 6"></path>
            </svg>
          </button>
        </form>
        <div class="proof">
          <span class="stack" aria-hidden="true">
            <span class="av"></span>
            <span class="av"></span>
            <span class="av"></span>
            <span class="av"></span>
          </span>
          Join <span class="num">400+ people</span> moving smarter
        </div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section class="band" id="problem">
      <div class="wrap">
        <div class="section-head">
          <div class="eyebrow">Sound familiar?</div>
          <h2>Moving is one of the most stressful life events. Most people wing it.</h2>
        </div>

        <div class="problem-grid">
          <article class="pain-card">
            <div class="pain-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="6" y="9" width="13" height="17" rx="1.5" transform="rotate(-8 12.5 17.5)"></rect>
                <rect x="10" y="6" width="13" height="17" rx="1.5" transform="rotate(4 16.5 14.5)"></rect>
                <rect x="14" y="10" width="13" height="17" rx="1.5" transform="rotate(-3 20.5 18.5)"></rect>
                <line x1="18" y1="14" x2="24" y2="14"></line>
                <line x1="18" y1="17" x2="24" y2="17"></line>
                <line x1="18" y1="20" x2="22" y2="20"></line>
              </svg>
            </div>
            <h3>You don't know what you're forgetting.</h3>
            <p>There's no master list. Just a growing dread that something important is slipping through.</p>
          </article>

          <article class="pain-card">
            <div class="pain-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="16" cy="16" r="11"></circle>
                <path d="M16 9v7l4.5 3"></path>
                <path d="M5 4l3 3"></path>
                <path d="M27 4l-3 3"></path>
              </svg>
            </div>
            <h3>Everything has a deadline you don't know about.</h3>
            <p>DMV updates, voter registration, insurance switches — all have windows. Miss them and pay for it.</p>
          </article>

          <article class="pain-card">
            <div class="pain-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 17l-3.5 3.5a4 4 0 0 1-5.6-5.6L6 11.5"></path>
                <path d="M21 15l3.5-3.5a4 4 0 0 1 5.6 5.6L26 20.5"></path>
                <path d="M13.5 19.5l-2 2"></path>
                <path d="M18.5 12.5l2-2"></path>
                <path d="M15 12l-3 3"></path>
                <path d="M17 17l3-3"></path>
              </svg>
            </div>
            <h3>Generic checklists don't fit your move.</h3>
            <p>Renting vs buying, local vs out of state, kids, pets — your move is specific. The list should be too.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- TRANSITION -->
    <section class="transition" aria-hidden="true">
      <div class="wrap">
        <div class="transition-inner">
          <div class="transition-rule"></div>
          <div class="transition-text">There's a better way.</div>
          <div class="transition-rule"></div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="band how">
      <div class="wrap">
        <div class="section-head">
          <div class="eyebrow">Simple by design</div>
          <h2>Three steps to a move where nothing gets missed.</h2>
        </div>

        <div class="steps">
          <div class="step">
            <div class="step-num">1</div>
            <div class="step-illu" aria-hidden="true">
              <svg viewBox="0 0 220 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="10" y="10" width="200" height="180" rx="10" fill="#FDFCFA" stroke="#E6DFD4"></rect>
                <text x="22" y="34" font-family="DM Sans, sans-serif" font-size="9" font-weight="500" fill="#7A8A99" letter-spacing="1.2">QUESTION 1 OF 5</text>
                <text x="22" y="58" font-family="Fraunces, serif" font-size="14" font-weight="400" fill="#2C3E50">When are you moving?</text>
                <rect x="22" y="74" width="80" height="28" rx="6" fill="#FDFCFA" stroke="#7CA98A" stroke-width="1.5"></rect>
                <text x="62" y="92" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="10" font-weight="500" fill="#2C3E50">Aug 15</text>
                <rect x="110" y="74" width="80" height="28" rx="6" fill="#FDFCFA" stroke="#E6DFD4"></rect>
                <text x="150" y="92" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="10" fill="#7A8A99">Pick a date</text>
                <line x1="22" y1="120" x2="60" y2="120" stroke="#7CA98A" stroke-width="2.5" stroke-linecap="round"></line>
                <line x1="62" y1="120" x2="78" y2="120" stroke="#E6DFD4" stroke-width="2.5" stroke-linecap="round"></line>
                <line x1="80" y1="120" x2="96" y2="120" stroke="#E6DFD4" stroke-width="2.5" stroke-linecap="round"></line>
                <line x1="98" y1="120" x2="114" y2="120" stroke="#E6DFD4" stroke-width="2.5" stroke-linecap="round"></line>
                <line x1="116" y1="120" x2="132" y2="120" stroke="#E6DFD4" stroke-width="2.5" stroke-linecap="round"></line>
                <rect x="22" y="140" width="100" height="14" rx="3" fill="#EFEAE3"></rect>
                <rect x="22" y="160" width="140" height="10" rx="3" fill="#EFEAE3" opacity="0.7"></rect>
                <rect x="148" y="156" width="50" height="22" rx="6" fill="#7CA98A"></rect>
                <text x="173" y="170" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="9" font-weight="500" fill="#FDFCFA">Next →</text>
              </svg>
            </div>
            <h3>Answer 5 questions about your move</h3>
            <p>Dates, distance, household, special considerations — under two minutes.</p>
          </div>

          <div class="step-arrow" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 16h20"></path>
              <path d="M20 8l8 8-8 8"></path>
            </svg>
          </div>

          <div class="step">
            <div class="step-num">2</div>
            <div class="step-illu" aria-hidden="true">
              <svg viewBox="0 0 220 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="10" y="10" width="200" height="180" rx="10" fill="#FDFCFA" stroke="#E6DFD4"></rect>
                <text x="22" y="32" font-family="DM Sans, sans-serif" font-size="9" font-weight="500" fill="#7CA98A" letter-spacing="1.2">8 WEEKS OUT</text>
                <circle cx="26" cy="50" r="6" fill="#FDFCFA" stroke="#7CA98A" stroke-width="1.5"></circle>
                <rect x="38" y="46" width="100" height="8" rx="2" fill="#2C3E50"></rect>
                <circle cx="26" cy="68" r="6" fill="#FDFCFA" stroke="#7CA98A" stroke-width="1.5"></circle>
                <rect x="38" y="64" width="120" height="8" rx="2" fill="#4A5C6E"></rect>
                <line x1="22" y1="86" x2="198" y2="86" stroke="#EFEAE3"></line>
                <text x="22" y="106" font-family="DM Sans, sans-serif" font-size="9" font-weight="500" fill="#7CA98A" letter-spacing="1.2">4 WEEKS OUT</text>
                <circle cx="26" cy="124" r="6" fill="#FDFCFA" stroke="#7CA98A" stroke-width="1.5"></circle>
                <rect x="38" y="120" width="140" height="8" rx="2" fill="#4A5C6E"></rect>
                <circle cx="26" cy="142" r="6" fill="#FDFCFA" stroke="#7CA98A" stroke-width="1.5"></circle>
                <rect x="38" y="138" width="110" height="8" rx="2" fill="#4A5C6E"></rect>
                <circle cx="26" cy="160" r="6" fill="#FDFCFA" stroke="#7CA98A" stroke-width="1.5"></circle>
                <rect x="38" y="156" width="90" height="8" rx="2" fill="#4A5C6E"></rect>
                <text x="22" y="182" font-family="DM Sans, sans-serif" font-size="8" fill="#7A8A99">+ 23 more tasks tailored to you</text>
              </svg>
            </div>
            <h3>Get your personalized checklist</h3>
            <p>Tasks sorted by phase, timed to your move date and tailored to your situation.</p>
          </div>

          <div class="step-arrow" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 16h20"></path>
              <path d="M20 8l8 8-8 8"></path>
            </svg>
          </div>

          <div class="step">
            <div class="step-num">3</div>
            <div class="step-illu" aria-hidden="true">
              <svg viewBox="0 0 220 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="10" y="10" width="200" height="180" rx="10" fill="#FDFCFA" stroke="#E6DFD4"></rect>
                <text x="22" y="32" font-family="DM Sans, sans-serif" font-size="9" font-weight="500" fill="#7A8A99" letter-spacing="1.2">YOUR PROGRESS</text>
                <text x="198" y="32" text-anchor="end" font-family="Fraunces, serif" font-size="13" font-weight="400" fill="#2C3E50">14 / 32</text>
                <rect x="22" y="40" width="176" height="8" rx="4" fill="#EFEAE3"></rect>
                <rect x="22" y="40" width="77" height="8" rx="4" fill="#7CA98A"></rect>
                <circle cx="30" cy="74" r="8" fill="#7CA98A"></circle>
                <path d="M26 74l3 3 5-5" stroke="#FDFCFA" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
                <rect x="44" y="70" width="120" height="8" rx="2" fill="#7A8A99"></rect>
                <text x="170" y="78" font-family="DM Sans, sans-serif" font-size="8" fill="#7CA98A">Done</text>
                <circle cx="30" cy="100" r="8" fill="#7CA98A"></circle>
                <path d="M26 100l3 3 5-5" stroke="#FDFCFA" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
                <rect x="44" y="96" width="100" height="8" rx="2" fill="#7A8A99"></rect>
                <text x="170" y="104" font-family="DM Sans, sans-serif" font-size="8" fill="#7CA98A">Done</text>
                <circle cx="30" cy="126" r="8" fill="#FDFCFA" stroke="#7CA98A" stroke-width="1.5"></circle>
                <rect x="44" y="122" width="140" height="8" rx="2" fill="#2C3E50"></rect>
                <text x="44" y="142" font-family="DM Sans, sans-serif" font-size="8" fill="#7A8A99">Due in 3 days</text>
                <circle cx="30" cy="160" r="8" fill="#FDFCFA" stroke="#E6DFD4" stroke-width="1.5"></circle>
                <rect x="44" y="156" width="110" height="8" rx="2" fill="#4A5C6E"></rect>
                <text x="44" y="176" font-family="DM Sans, sans-serif" font-size="8" fill="#7A8A99">Next week</text>
              </svg>
            </div>
            <h3>Check off tasks as you go — nothing missed</h3>
            <p>Progress, deadlines, and gentle nudges keep you on track from week eight to move day.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="band" id="features">
      <div class="wrap">
        <div class="section-head">
          <div class="eyebrow">What's inside</div>
          <h2>Everything your move needs. Nothing it doesn't.</h2>
        </div>

        <div class="features-grid">
          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="17" rx="2"></rect>
                <path d="M7 9l2 2 4-4"></path>
                <path d="M14 9h4"></path>
                <path d="M7 16l2 2 4-4"></path>
                <path d="M14 17h4"></path>
              </svg>
            </div>
            <h3>Smart Checklist Engine</h3>
            <p>Tasks sorted by phase — 8 weeks out through 30 days after. Each one timed to your move date.</p>
          </article>

          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-7.5 8-13a8 8 0 0 0-16 0c0 5.5 8 13 8 13z"></path>
                <circle cx="12" cy="9" r="2.8"></circle>
              </svg>
            </div>
            <h3>Address Change Tracker</h3>
            <p>Every place that needs your new address in one list. Bank, IRS, employer, subscriptions — check them off as you go.</p>
          </article>

          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"></path>
              </svg>
            </div>
            <h3>Utility Command Center</h3>
            <p>Cancel old utilities, set up new ones, transfer internet — all coordinated around your move date.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- TESTIMONIAL -->
    <section class="testimonial">
      <div class="wrap">
        <div class="quote-mark" aria-hidden="true">"</div>
        <blockquote>
          I've moved six times. This is the first time I didn't spend the first month realizing things I forgot to do.
        </blockquote>
        <div class="attrib">
          <div class="attrib-avatar" aria-hidden="true"></div>
          <div class="attrib-text">
            <div class="attrib-name">Sarah K.</div>
            <div class="attrib-role">Renter → First-time homeowner, Atlanta&nbsp;GA</div>
          </div>
        </div>
      </div>
    </section>

    <!-- SETTLED / POST-MOVE TEASER -->
    <section class="settled band" id="settled">
      <div class="wrap">
        <div class="section-head">
          <div class="settled-badge">
            <span class="badge-dot"></span>
            Coming soon
          </div>
          <h2>The move ends. MoveMatters doesn't.</h2>
          <p class="settled-sub">Once the boxes are unpacked, Settled Mode keeps you on top of your new home — automatically.</p>
        </div>

        <div class="settled-grid">
          <div class="settled-card">
            <div class="settled-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
              </svg>
            </div>
            <h3>Home Maintenance Reminders</h3>
            <p>Seasonal reminders for HVAC filters, gutter cleaning, smoke detectors — all tied to your zip code and move-in date.</p>
          </div>

          <div class="settled-card">
            <div class="settled-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
            </div>
            <h3>Appliance &amp; Warranty Tracker</h3>
            <p>Log your appliances, purchase dates, and warranty windows. We'll remind you before they expire — not after.</p>
          </div>

          <div class="settled-card">
            <div class="settled-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                <path d="M16 2v4"></path>
                <path d="M8 2v4"></path>
                <path d="M3 10h18"></path>
                <path d="M8 14h.01"></path>
                <path d="M12 14h.01"></path>
                <path d="M16 14h.01"></path>
                <path d="M8 18h.01"></path>
                <path d="M12 18h.01"></path>
              </svg>
            </div>
            <h3>Life Admin Deadlines</h3>
            <p>Property tax due dates, voter registration windows, DMV renewal reminders — county-specific and always on time.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA 2 -->
    <section class="cta2" id="waitlist">
      <div class="wrap">
        <h2>Your move matters. Don't leave it to chance.</h2>
        <p class="sub">Join the waitlist and be first to know when MoveMatters launches.</p>
        <form class="hero-form" name="waitlist-cta" data-netlify="true" onsubmit="handleNetlifySignup(event, this);">
          <input type="hidden" name="form-name" value="waitlist-cta" />
          <input class="input" type="email" name="email" placeholder="your@email.com" aria-label="Email address" required />
          <button class="btn btn-primary btn-arrow" type="submit">
            Join the Waitlist
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="M13 6l6 6-6 6"></path>
            </svg>
          </button>
        </form>
        <div class="reassure">No spam. Just a heads up when we launch.</div>
      </div>
    </section>

  </main>
</BaseLayout>

<script is:inline>
  function handleNetlifySignup(e, form) {
    e.preventDefault();
    var input = form.querySelector('input[type="email"]');
    var btn = form.querySelector('button[type="submit"]');
    if (!input || !input.value) return;
    var email = input.value;
    var formName = form.getAttribute('name');
    var original = btn.innerHTML;
    btn.disabled = true;
    btn.style.opacity = '0.7';
    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: 'form-name=' + encodeURIComponent(formName) + '&email=' + encodeURIComponent(email)
    })
      .then(function () {
        btn.innerHTML = '&#10003; You&#39;re on the list';
        btn.style.background = '#58836A';
        btn.style.opacity = '1';
        input.value = '';
        input.placeholder = 'See you soon!';
        setTimeout(function () {
          btn.innerHTML = original;
          btn.disabled = false;
          btn.style.background = '';
          input.placeholder = 'your@email.com';
        }, 4000);
      })
      .catch(function () {
        btn.innerHTML = original;
        btn.disabled = false;
        btn.style.opacity = '1';
      });
  }
</script>
